# Required exchange credentials
MEXC_API_KEY=replace_me
MEXC_API_SECRET=replace_me

# Runtime
DRY_RUN=true
USDT_PER_TRADE=25
TIMEFRAME=1m
OHLCV_LIMIT=500
POLL_SECONDS=20

# Slots / risk sizing
MAX_DIP_SLOTS=2
MAX_MOMENTUM_SLOTS=7
MAX_MADIP_SLOTS=3
BALANCE_USE_PCT=0.95
MIN_FREE_RESERVE_USDT=5

# Dashboard security defaults
# Keep local-only by default. Use Nginx reverse proxy if you need remote access.
DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=8050
# Optional: set for API/header-based dashboard auth.
# For SSH tunnel + normal browser usage, you can keep this empty.
DASHBOARD_TOKEN=
# Keep false in production unless you know what you are doing.
DASHBOARD_ALLOW_PUBLIC_NO_AUTH=false
# Optional custom dashboard html file name (served from repo root)
DASHBOARD_HTML_FILE=dashboard_v4.html


